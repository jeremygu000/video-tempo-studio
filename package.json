{
  "name": "video-tempo-studio",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "start": "npm run start -w web",
    "lint": "npm run lint -w web",
    "typecheck": "npm run typecheck -w web",
    "db:init": "npm run db:init -w backend",
    "worker:once": "npm run worker:once -w backend",
    "worker:watch": "npm run worker:watch -w backend",
    "worker:pm2:start": "npx pm2 start npm --name video-worker -- run worker:watch && npm run worker:pm2:ensure",
    "worker:pm2:ensure": "npx pm2 scale video-worker 1 || true",
    "worker:pm2:stop": "npx pm2 stop video-worker",
    "worker:pm2:restart": "npx pm2 restart video-worker",
    "worker:pm2:delete": "npx pm2 delete video-worker",
    "worker:pm2:logs": "npx pm2 logs video-worker",
    "worker:pm2:status": "npx pm2 status",
    "worker:pm2:save": "npx pm2 save",
    "worker:pm2:startup": "npx pm2 startup",
    "web:pm2:start": "npx pm2 start npm --name video-web -- run start",
    "web:pm2:stop": "npx pm2 stop video-web",
    "web:pm2:restart": "npx pm2 restart video-web",
    "web:pm2:delete": "npx pm2 delete video-web",
    "web:pm2:logs": "npx pm2 logs video-web",
    "pm2:start:all": "npm run build -w web && npm run worker:pm2:start && npm run web:pm2:start",
    "pm2:stop:all": "npm run worker:pm2:stop && npm run web:pm2:stop",
    "pm2:restart:all": "npm run worker:pm2:restart && npm run web:pm2:restart",
    "pm2:delete:all": "npm run worker:pm2:delete && npm run web:pm2:delete",
    "mac:awake": "caffeinate -dimsu",
    "mac:awake:screen-off": "caffeinate -is",
    "video:run": "npm run video:run -w backend",
    "test:python": "npm run test:python -w backend",
    "test:web": "npm run test:web -w web",
    "test:all": "npm run test:python && npm run test:web"
  },
  "devDependencies": {
    "pm2": "^6.0.14"
  }
}
