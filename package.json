{
  "name": "video-tempo-studio",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "start": "npm run start -w web",
    "lint": "npm run lint -w web",
    "typecheck": "npm run typecheck -w web",
    "db:init": "npm run db:init -w backend",
    "worker:once": "npm run worker:once -w backend",
    "worker:watch": "npm run worker:watch -w backend",
    "video:run": "npm run video:run -w backend",
    "test:python": "npm run test:python -w backend",
    "test:web": "npm run test:web -w web",
    "test:all": "npm run test:python && npm run test:web"
  }
}
